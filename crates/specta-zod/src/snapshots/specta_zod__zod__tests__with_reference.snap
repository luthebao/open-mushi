export const simpleStructSchema = z.object({
  name: z.string(),
  age: z.number(),
  active: z.boolean(),
});
export type SimpleStruct = z.infer<typeof simpleStructSchema>;

export const withReferenceSchema = z.object({
  simple: simpleStructSchema,
});
export type WithReference = z.infer<typeof withReferenceSchema>;
